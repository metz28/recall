# API Configuration
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# Authentication - REQUIRED
# Generate a strong secret key with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Database Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333
KUZU_PATH=/data/kuzu
SQLITE_PATH=/data/recall.db

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# LLM Configuration (optional - for entity extraction and chat)
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# Notion Integration (optional)
# NOTION_API_KEY=your_notion_integration_token_here

# Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Application Settings
MAX_UPLOAD_SIZE=50  # MB
ALLOWED_EXTENSIONS=.txt,.pdf,.docx,.md,.html
